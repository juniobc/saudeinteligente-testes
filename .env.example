# ============================================
# Guardian — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha com seus valores reais.
# Exemplo: cp .env.example .env

# URL base do SPA em desenvolvimento local.
# Aponta para o servidor de desenvolvimento do saudeinteligente-spa.
E2E_BASE_URL=http://localhost:5173

# Credenciais de autenticação para o fluxo de login do global-setup.
# O Guardian usa essas credenciais para realizar login e persistir o estado de sessão.
E2E_USERNAME=seu_usuario
E2E_PASSWORD=sua_senha

# Município selecionado após o login (valor do select de municípios).
# Exemplo: go_luziania, go_goiania, etc.
E2E_MUNICIPIO=go_luziania

# Modo de execução do navegador.
# false = headed (padrão) — o navegador abre visualmente para acompanhamento.
# true  = headless — execução sem interface gráfica (útil para CI/CD).
E2E_HEADLESS=false

# Atraso em milissegundos entre cada ação do Playwright.
# Valor padrão: 300ms — permite acompanhar visualmente as ações.
# Use 0 para execução rápida em CI/CD.
E2E_SLOW_MO=300
